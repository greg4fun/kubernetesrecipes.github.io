---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import RecipeCard from "../../../components/recipe-card.astro";

export async function getStaticPaths() {
  const categoryMeta: Record<string, { name: string; icon: string; description: string; color: string }> = {
    networking: {
      name: "Networking",
      icon: "🌐",
      color: "blue",
      description: "Master Kubernetes networking: Services, Ingress, Network Policies, DNS, load balancing, SR-IOV, NNCP, InfiniBand, and multi-NIC configurations for production clusters."
    },
    storage: {
      name: "Storage",
      icon: "💾",
      color: "yellow",
      description: "Persistent storage patterns: PVCs, StorageClasses, NFS-oRDMA, volume expansion, backup with Velero, model storage for AI workloads, and high-performance storage tuning."
    },
    security: {
      name: "Security",
      icon: "🔒",
      color: "red",
      description: "Secure your clusters: RBAC, Pod Security Standards, Network Policies, secrets management, image scanning, RHACS, OpenClaw security hardening, and compliance automation."
    },
    deployments: {
      name: "Deployments",
      icon: "🚀",
      color: "green",
      description: "Deployment strategies and patterns: Rolling updates, blue-green, canary, ArgoCD GitOps, Kustomize overlays, OpenShift, OpenClaw on K8s, and multi-cluster management."
    },
    observability: {
      name: "Observability",
      icon: "📊",
      color: "orange",
      description: "Monitor everything: Prometheus, Grafana dashboards, EFK logging, distributed tracing with Jaeger, health probes, custom metrics, and GPU monitoring for AI workloads."
    },
    troubleshooting: {
      name: "Troubleshooting",
      icon: "🔧",
      color: "pink",
      description: "Debug and fix: CrashLoopBackOff, OOMKilled, ImagePullBackOff, pending pods, networking issues, SR-IOV VF troubleshooting, and NFS-oRDMA performance debugging."
    },
    autoscaling: {
      name: "Autoscaling",
      icon: "⚡",
      color: "cyan",
      description: "Scale intelligently: HPA, VPA, Cluster Autoscaler, KEDA event-driven scaling, GPU metrics autoscaling, custom metrics, and cost optimization strategies."
    },
    configuration: {
      name: "Configuration",
      icon: "⚙️",
      color: "gray",
      description: "Configure K8s right: ConfigMaps, Secrets, resource limits, node management, MachineConfigPools, GPU Operator, NicClusterPolicy, and DOCA driver builds."
    },
    helm: {
      name: "Helm",
      icon: "🎯",
      color: "teal",
      description: "Helm mastery: Chart development, template functions, hooks, repositories, dependency management, and Helm-based deployment patterns for complex applications."
    },
    ai: {
      name: "AI & GPU",
      icon: "🤖",
      color: "purple",
      description: "AI/ML on Kubernetes: GPU scheduling, NVIDIA Triton, vLLM, model deployment (Llama, Qwen, Phi-4), distributed training, Kubeflow, NeMo, and inference optimization."
    },
  };

  const allRecipes = await getCollection("recipes");
  const categories = [...new Set(allRecipes.filter((r: any) => !r.data.draft).map((r: any) => r.data.category))];

  return categories.map((category: string) => {
    const meta = categoryMeta[category] || {
      name: category.charAt(0).toUpperCase() + category.slice(1),
      icon: "📄",
      color: "gray",
      description: `Kubernetes ${category} recipes and production patterns.`
    };
    return {
      params: { category },
      props: { meta },
    };
  });
}

const { category } = Astro.params;
const { meta } = Astro.props;

const allRecipes = await getCollection("recipes");
const recipes = allRecipes
  .filter((r: any) => r.data.category === category && !r.data.draft)
  .sort((a: any, b: any) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

// Difficulty breakdown
const diffCounts = { beginner: 0, intermediate: 0, advanced: 0 };
recipes.forEach((r: any) => { if (r.data.difficulty) diffCounts[r.data.difficulty]++; });
---

<Layout
  title={`${meta.icon} ${meta.name} Recipes - Kubernetes Production Patterns`}
  description={meta.description}
>
  <main class="category-page">
    <section class="cat-hero">
      <nav class="breadcrumb">
        <a href="/">Home</a> / <a href="/recipes/">Recipes</a> / <span>{meta.name}</span>
      </nav>
      <h1>{meta.icon} {meta.name}</h1>
      <p class="cat-desc">{meta.description}</p>
      <div class="cat-stats">
        <span class="stat">{recipes.length} recipes</span>
        {diffCounts.beginner > 0 && <span class="stat stat-beginner">🟢 {diffCounts.beginner} beginner</span>}
        {diffCounts.intermediate > 0 && <span class="stat stat-intermediate">🟡 {diffCounts.intermediate} intermediate</span>}
        {diffCounts.advanced > 0 && <span class="stat stat-advanced">🔴 {diffCounts.advanced} advanced</span>}
      </div>
    </section>

    <section class="cat-recipes">
      <div class="cat-grid">
        {recipes.map((recipe: any) => (
          <a href={`/recipes/${category}/${recipe.slug}/`} class="cat-card">
            <div class="cat-card-head">
              {recipe.data.difficulty && (
                <span class={`diff-badge diff-${recipe.data.difficulty}`}>{recipe.data.difficulty}</span>
              )}
              {recipe.data.timeToComplete && (
                <span class="time-badge">⏱ {recipe.data.timeToComplete}</span>
              )}
            </div>
            <h3>{recipe.data.title}</h3>
            <p>{recipe.data.description}</p>
            <div class="cat-card-tags">
              {(recipe.data.tags || []).slice(0, 4).map((tag: string) => (
                <span class="mini-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <style>
    .category-page { max-width: 1100px; margin: 0 auto; padding: 0 1rem; }
    .breadcrumb { font-size: 0.82rem; color: #94a3b8; margin-bottom: 0.5rem; }
    .breadcrumb a { color: #64748b; text-decoration: none; }
    .breadcrumb a:hover { color: #3b82f6; }
    .cat-hero { padding: 2rem 0 1.5rem; border-bottom: 1px solid #e2e8f0; margin-bottom: 1.5rem; }
    .cat-hero h1 { font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem; color: #1e293b; }
    .cat-desc { color: #64748b; font-size: 1rem; line-height: 1.5; margin: 0 0 1rem; max-width: 700px; }
    .cat-stats { display: flex; gap: 1rem; flex-wrap: wrap; }
    .stat {
      font-size: 0.82rem; font-weight: 600; padding: 0.2rem 0.6rem;
      border-radius: 6px; background: #f1f5f9; color: #475569;
    }
    .cat-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1rem; padding-bottom: 3rem;
    }
    .cat-card {
      padding: 1rem; border-radius: 10px; border: 1px solid #e2e8f0;
      background: #fff; text-decoration: none; color: inherit;
      transition: all 0.15s;
    }
    .cat-card:hover { border-color: #3b82f6; box-shadow: 0 2px 8px rgba(59,130,246,0.1); }
    .cat-card-head { display: flex; gap: 0.5rem; margin-bottom: 0.4rem; }
    .diff-badge {
      font-size: 0.7rem; font-weight: 500; padding: 0.1rem 0.4rem;
      border-radius: 4px; text-transform: capitalize;
    }
    .diff-beginner { background: #dcfce7; color: #16a34a; }
    .diff-intermediate { background: #fef9c3; color: #a16207; }
    .diff-advanced { background: #fee2e2; color: #dc2626; }
    .time-badge { font-size: 0.7rem; color: #94a3b8; }
    .cat-card h3 { font-size: 0.92rem; font-weight: 700; margin: 0 0 0.3rem; color: #1e293b; line-height: 1.3; }
    .cat-card:hover h3 { color: #2563eb; }
    .cat-card p {
      font-size: 0.8rem; color: #64748b; line-height: 1.4; margin: 0 0 0.5rem;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .cat-card-tags { display: flex; gap: 0.2rem; flex-wrap: wrap; }
    .mini-tag { font-size: 0.65rem; padding: 0.05rem 0.3rem; border-radius: 3px; background: #f1f5f9; color: #64748b; }
    @media (max-width: 640px) { .cat-grid { grid-template-columns: 1fr; } }
  </style>
</Layout>
