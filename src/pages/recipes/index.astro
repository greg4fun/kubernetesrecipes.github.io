---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const recipes = (await getCollection("recipes"))
  .filter((r: any) => !r.data.draft)
  .sort((a: any, b: any) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const categories = [
  { id: "ai", name: "AI & GPU", icon: "🤖", color: "purple" },
  { id: "networking", name: "Networking", icon: "🌐", color: "blue" },
  { id: "security", name: "Security", icon: "🔒", color: "red" },
  { id: "deployments", name: "Deployments", icon: "🚀", color: "green" },
  { id: "storage", name: "Storage", icon: "💾", color: "yellow" },
  { id: "observability", name: "Observability", icon: "📊", color: "orange" },
  { id: "autoscaling", name: "Autoscaling", icon: "⚡", color: "cyan" },
  { id: "configuration", name: "Configuration", icon: "⚙️", color: "gray" },
  { id: "helm", name: "Helm", icon: "🎯", color: "teal" },
  { id: "troubleshooting", name: "Troubleshooting", icon: "🔧", color: "pink" },
];

const difficulties = ["beginner", "intermediate", "advanced"];

// Collect all unique tags
const tagCounts: Record<string, number> = {};
recipes.forEach((r: any) => {
  (r.data.tags || []).forEach((t: string) => {
    tagCounts[t] = (tagCounts[t] || 0) + 1;
  });
});
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 30)
  .map(([tag]) => tag);

// Category counts
const catCounts: Record<string, number> = {};
recipes.forEach((r: any) => {
  catCounts[r.data.category] = (catCounts[r.data.category] || 0) + 1;
});

// Serialize recipes for client-side search
const recipesData = recipes.map((r: any) => ({
  slug: r.slug,
  title: r.data.title,
  description: r.data.description,
  category: r.data.category,
  difficulty: r.data.difficulty,
  tags: r.data.tags || [],
  publishDate: r.data.publishDate,
  timeToComplete: r.data.timeToComplete || "",
}));
---

<Layout
  title="All Recipes"
  description="Browse 400+ Kubernetes recipes. Search by category, difficulty, or topic — from AI/GPU workloads to networking, security, and more."
>
  <main class="recipes-hub">
    <!-- Hero Search -->
    <section class="hub-hero">
      <div class="hub-hero-inner">
        <h1>Kubernetes Recipes</h1>
        <p class="hub-subtitle">{recipes.length} production-ready recipes for every K8s challenge</p>
        <div class="search-box">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input
            type="search"
            id="recipe-search"
            placeholder="Search recipes... (e.g. HPA, GPU, ArgoCD, secrets)"
            autocomplete="off"
            spellcheck="false"
          />
          <kbd class="search-kbd">⌘K</kbd>
        </div>
        <div class="search-stats" id="search-stats">{recipes.length} recipes</div>
      </div>
    </section>

    <!-- Filters -->
    <section class="hub-filters">
      <div class="hub-filters-inner">
        <!-- Category pills -->
        <div class="filter-group">
          <div class="filter-tabs">
            <button class="filter-tab active" data-filter="categories">Categories</button>
            <button class="filter-tab" data-filter="difficulty">Difficulty</button>
            <button class="filter-tab" data-filter="tags">Popular Tags</button>
          </div>
          
          <div class="filter-panel active" id="panel-categories">
            <div class="pill-grid">
              {categories.map((cat) => (
                <button
                  class={`cat-pill cat-pill-${cat.color}`}
                  data-category={cat.id}
                >
                  <span class="pill-icon">{cat.icon}</span>
                  <span class="pill-name">{cat.name}</span>
                  <span class="pill-count">{catCounts[cat.id] || 0}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="filter-panel" id="panel-difficulty">
            <div class="pill-grid">
              {difficulties.map((d) => (
                <button
                  class={`diff-pill diff-pill-${d}`}
                  data-difficulty={d}
                >
                  <span class="pill-name">{d}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="filter-panel" id="panel-tags">
            <div class="pill-grid pill-grid-tags">
              {topTags.map((tag) => (
                <button class="tag-pill" data-tag={tag}>
                  {tag}
                  <span class="pill-count">{tagCounts[tag]}</span>
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Active filters -->
        <div class="active-filters" id="active-filters" style="display:none">
          <span class="active-label">Filters:</span>
          <div id="active-filter-chips"></div>
          <button class="clear-all" id="clear-filters">Clear all</button>
        </div>

        <!-- Sort -->
        <div class="sort-bar">
          <select id="sort-select">
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
            <option value="az">A → Z</option>
            <option value="za">Z → A</option>
          </select>
        </div>
      </div>
    </section>

    <!-- Results -->
    <section class="hub-results">
      <div class="hub-results-inner">
        <div class="recipe-grid" id="recipe-grid">
          {recipes.map((recipe: any) => (
            <a
              href={`/recipes/${recipe.data.category}/${recipe.slug}/`}
              class="recipe-card"
              data-category={recipe.data.category}
              data-difficulty={recipe.data.difficulty}
              data-tags={(recipe.data.tags || []).join(",")}
              data-title={recipe.data.title.toLowerCase()}
              data-desc={recipe.data.description.toLowerCase()}
            >
              <div class="card-header">
                <span class={`card-cat card-cat-${recipe.data.category}`}>
                  {categories.find(c => c.id === recipe.data.category)?.icon}{" "}
                  {categories.find(c => c.id === recipe.data.category)?.name || recipe.data.category}
                </span>
                {recipe.data.difficulty && (
                  <span class={`card-diff card-diff-${recipe.data.difficulty}`}>
                    {recipe.data.difficulty}
                  </span>
                )}
              </div>
              <h3 class="card-title">{recipe.data.title}</h3>
              <p class="card-desc">{recipe.data.description}</p>
              <div class="card-meta">
                {recipe.data.timeToComplete && (
                  <span class="card-time">⏱ {recipe.data.timeToComplete}</span>
                )}
                <span class="card-tags">
                  {(recipe.data.tags || []).slice(0, 3).map((tag: string) => (
                    <span class="card-tag">{tag}</span>
                  ))}
                </span>
              </div>
            </a>
          ))}
        </div>
        <!-- Pagination -->
        <div class="pagination" id="pagination"></div>
        <div class="no-results" id="no-results" style="display:none">
          <p class="no-results-icon">🔍</p>
          <p class="no-results-text">No recipes found</p>
          <p class="no-results-hint">Try different keywords or clear your filters</p>
        </div>
      </div>
    </section>
  </main>

  <script define:vars={{ recipesData }}>
    // Client-side search, filter & pagination
    const searchInput = document.getElementById("recipe-search");
    const grid = document.getElementById("recipe-grid");
    const cards = Array.from(grid.querySelectorAll(".recipe-card"));
    const statsEl = document.getElementById("search-stats");
    const noResults = document.getElementById("no-results");
    const activeFiltersEl = document.getElementById("active-filters");
    const activeChipsEl = document.getElementById("active-filter-chips");
    const clearBtn = document.getElementById("clear-filters");
    const sortSelect = document.getElementById("sort-select");
    const paginationEl = document.getElementById("pagination");

    const PAGE_SIZE = 24;
    let currentPage = 1;
    let filteredCards = [...cards];
    let filters = { categories: [], difficulty: [], tags: [], query: "" };

    // Filter tabs
    document.querySelectorAll(".filter-tab").forEach(tab => {
      tab.addEventListener("click", () => {
        document.querySelectorAll(".filter-tab").forEach(t => t.classList.remove("active"));
        document.querySelectorAll(".filter-panel").forEach(p => p.classList.remove("active"));
        tab.classList.add("active");
        document.getElementById("panel-" + tab.dataset.filter).classList.add("active");
      });
    });

    // Category pills
    document.querySelectorAll(".cat-pill").forEach(pill => {
      pill.addEventListener("click", () => {
        const cat = pill.dataset.category;
        pill.classList.toggle("selected");
        if (filters.categories.includes(cat)) {
          filters.categories = filters.categories.filter(c => c !== cat);
        } else {
          filters.categories.push(cat);
        }
        currentPage = 1;
        applyFilters();
      });
    });

    // Difficulty pills
    document.querySelectorAll(".diff-pill").forEach(pill => {
      pill.addEventListener("click", () => {
        const d = pill.dataset.difficulty;
        pill.classList.toggle("selected");
        if (filters.difficulty.includes(d)) {
          filters.difficulty = filters.difficulty.filter(x => x !== d);
        } else {
          filters.difficulty.push(d);
        }
        currentPage = 1;
        applyFilters();
      });
    });

    // Tag pills
    document.querySelectorAll(".tag-pill").forEach(pill => {
      pill.addEventListener("click", () => {
        const t = pill.dataset.tag;
        pill.classList.toggle("selected");
        if (filters.tags.includes(t)) {
          filters.tags = filters.tags.filter(x => x !== t);
        } else {
          filters.tags.push(t);
        }
        currentPage = 1;
        applyFilters();
      });
    });

    // Search
    let searchTimeout;
    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        filters.query = searchInput.value.toLowerCase().trim();
        currentPage = 1;
        applyFilters();
      }, 150);
    });

    // Keyboard shortcut
    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        searchInput.focus();
      }
      if (e.key === "Escape" && document.activeElement === searchInput) {
        searchInput.blur();
      }
    });

    // Sort
    sortSelect.addEventListener("change", () => { currentPage = 1; applyFilters(); });

    // Clear
    clearBtn.addEventListener("click", () => {
      filters = { categories: [], difficulty: [], tags: [], query: "" };
      searchInput.value = "";
      currentPage = 1;
      document.querySelectorAll(".selected").forEach(el => el.classList.remove("selected"));
      applyFilters();
    });

    function applyFilters() {
      const q = filters.query;

      // Filter
      filteredCards = cards.filter(card => {
        const cat = card.dataset.category;
        const diff = card.dataset.difficulty;
        const tags = card.dataset.tags;
        const title = card.dataset.title;
        const desc = card.dataset.desc;

        if (filters.categories.length && !filters.categories.includes(cat)) return false;
        if (filters.difficulty.length && !filters.difficulty.includes(diff)) return false;
        if (filters.tags.length && !filters.tags.some(t => tags.includes(t))) return false;
        if (q && !title.includes(q) && !desc.includes(q) && !tags.includes(q) && !cat.includes(q)) return false;
        return true;
      });

      // Sort
      const sortVal = sortSelect.value;
      if (sortVal === "az") filteredCards.sort((a, b) => a.dataset.title.localeCompare(b.dataset.title));
      else if (sortVal === "za") filteredCards.sort((a, b) => b.dataset.title.localeCompare(a.dataset.title));

      // Paginate
      const totalPages = Math.max(1, Math.ceil(filteredCards.length / PAGE_SIZE));
      if (currentPage > totalPages) currentPage = totalPages;
      const start = (currentPage - 1) * PAGE_SIZE;
      const end = start + PAGE_SIZE;

      // Show/hide cards
      cards.forEach(c => c.style.display = "none");
      filteredCards.slice(start, end).forEach(c => { c.style.display = ""; grid.appendChild(c); });

      // Stats
      const showing = Math.min(end, filteredCards.length);
      statsEl.textContent = filteredCards.length === 0 
        ? "0 recipes" 
        : `Showing ${start + 1}–${showing} of ${filteredCards.length} recipes`;
      noResults.style.display = filteredCards.length === 0 ? "" : "none";
      grid.style.display = filteredCards.length === 0 ? "none" : "";

      // Render pagination
      renderPagination(totalPages);

      // Active filters display
      const hasFilters = filters.categories.length || filters.difficulty.length || filters.tags.length || filters.query;
      activeFiltersEl.style.display = hasFilters ? "" : "none";
      activeChipsEl.innerHTML = "";
      [...filters.categories, ...filters.difficulty, ...filters.tags].forEach(f => {
        const chip = document.createElement("span");
        chip.className = "filter-chip";
        chip.textContent = f;
        chip.addEventListener("click", () => {
          filters.categories = filters.categories.filter(x => x !== f);
          filters.difficulty = filters.difficulty.filter(x => x !== f);
          filters.tags = filters.tags.filter(x => x !== f);
          document.querySelectorAll(`[data-category="${f}"],[data-difficulty="${f}"],[data-tag="${f}"]`).forEach(el => el.classList.remove("selected"));
          currentPage = 1;
          applyFilters();
        });
        activeChipsEl.appendChild(chip);
      });
      if (filters.query) {
        const chip = document.createElement("span");
        chip.className = "filter-chip";
        chip.textContent = `"${filters.query}"`;
        chip.addEventListener("click", () => { filters.query = ""; searchInput.value = ""; currentPage = 1; applyFilters(); });
        activeChipsEl.appendChild(chip);
      }
    }

    function renderPagination(totalPages) {
      paginationEl.innerHTML = "";
      if (totalPages <= 1) return;

      // Prev button
      const prev = document.createElement("button");
      prev.textContent = "← Prev";
      prev.className = "page-btn" + (currentPage === 1 ? " disabled" : "");
      prev.disabled = currentPage === 1;
      prev.addEventListener("click", () => { if (currentPage > 1) { currentPage--; applyFilters(); scrollToGrid(); } });
      paginationEl.appendChild(prev);

      // Page numbers with ellipsis
      const pages = [];
      pages.push(1);
      if (currentPage > 3) pages.push("...");
      for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) {
        pages.push(i);
      }
      if (currentPage < totalPages - 2) pages.push("...");
      if (totalPages > 1) pages.push(totalPages);

      pages.forEach(p => {
        if (p === "...") {
          const dots = document.createElement("span");
          dots.textContent = "…";
          dots.className = "page-dots";
          paginationEl.appendChild(dots);
        } else {
          const btn = document.createElement("button");
          btn.textContent = p;
          btn.className = "page-btn" + (p === currentPage ? " active" : "");
          btn.addEventListener("click", () => { currentPage = p; applyFilters(); scrollToGrid(); });
          paginationEl.appendChild(btn);
        }
      });

      // Next button
      const next = document.createElement("button");
      next.textContent = "Next →";
      next.className = "page-btn" + (currentPage === totalPages ? " disabled" : "");
      next.disabled = currentPage === totalPages;
      next.addEventListener("click", () => { if (currentPage < totalPages) { currentPage++; applyFilters(); scrollToGrid(); } });
      paginationEl.appendChild(next);
    }

    function scrollToGrid() {
      document.querySelector(".hub-filters").scrollIntoView({ behavior: "smooth", block: "start" });
    }

    // Initial render with pagination
    applyFilters();
  </script>

  <style>
    .recipes-hub { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }

    /* Hero */
    .hub-hero { text-align: center; padding: 3rem 0 1.5rem; }
    .hub-hero h1 { font-size: 2.2rem; font-weight: 800; margin: 0 0 0.3rem; color: #1a1a2e; }
    .hub-subtitle { color: #666; font-size: 1.05rem; margin: 0 0 1.5rem; }
    .search-box {
      position: relative; max-width: 600px; margin: 0 auto;
    }
    .search-box input {
      width: 100%; padding: 0.8rem 1rem 0.8rem 2.8rem;
      border: 2px solid #e2e8f0; border-radius: 12px;
      font-size: 1rem; background: #fff;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }
    .search-box input:focus {
      border-color: #3b82f6; box-shadow: 0 0 0 4px rgba(59,130,246,0.1);
    }
    .search-icon {
      position: absolute; left: 0.9rem; top: 50%; transform: translateY(-50%);
      width: 1.1rem; height: 1.1rem; color: #9ca3af;
    }
    .search-kbd {
      position: absolute; right: 0.8rem; top: 50%; transform: translateY(-50%);
      background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 4px;
      padding: 0.1rem 0.4rem; font-size: 0.75rem; color: #94a3b8;
      font-family: system-ui;
    }
    .search-stats { color: #9ca3af; font-size: 0.85rem; margin-top: 0.5rem; }

    /* Filters */
    .hub-filters { margin-bottom: 1.5rem; }
    .filter-tabs {
      display: flex; gap: 0.25rem; margin-bottom: 0.75rem;
      border-bottom: 1px solid #e2e8f0; padding-bottom: 0;
    }
    .filter-tab {
      padding: 0.4rem 0.8rem; border: none; background: none;
      cursor: pointer; font-size: 0.85rem; font-weight: 500;
      color: #64748b; border-bottom: 2px solid transparent;
      transition: all 0.15s;
    }
    .filter-tab:hover { color: #334155; }
    .filter-tab.active { color: #1e293b; border-bottom-color: #3b82f6; }
    .filter-panel { display: none; }
    .filter-panel.active { display: block; }

    .pill-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .pill-grid-tags { gap: 0.35rem; }

    /* Category pills */
    .cat-pill {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.4rem 0.75rem; border-radius: 8px;
      border: 1px solid #e2e8f0; background: #fff;
      cursor: pointer; font-size: 0.85rem; font-weight: 500;
      transition: all 0.15s; color: #334155;
    }
    .cat-pill:hover { border-color: #cbd5e1; background: #f8fafc; }
    .cat-pill.selected { border-color: #3b82f6; background: #eff6ff; color: #1d4ed8; }
    .pill-icon { font-size: 1rem; }
    .pill-count {
      background: #f1f5f9; padding: 0.05rem 0.4rem; border-radius: 10px;
      font-size: 0.7rem; color: #64748b; font-weight: 600;
    }
    .cat-pill.selected .pill-count { background: #dbeafe; color: #2563eb; }

    /* Difficulty pills */
    .diff-pill {
      padding: 0.35rem 0.8rem; border-radius: 20px;
      border: 1px solid #e2e8f0; background: #fff;
      cursor: pointer; font-size: 0.8rem; font-weight: 500;
      text-transform: capitalize; transition: all 0.15s;
    }
    .diff-pill:hover { background: #f8fafc; }
    .diff-pill.selected { border-color: #3b82f6; background: #eff6ff; color: #1d4ed8; }
    .diff-pill-beginner { color: #16a34a; }
    .diff-pill-intermediate { color: #ca8a04; }
    .diff-pill-advanced { color: #dc2626; }

    /* Tag pills */
    .tag-pill {
      display: inline-flex; align-items: center; gap: 0.3rem;
      padding: 0.25rem 0.6rem; border-radius: 6px;
      border: 1px solid #e2e8f0; background: #fff;
      cursor: pointer; font-size: 0.78rem; color: #475569;
      transition: all 0.15s;
    }
    .tag-pill:hover { border-color: #cbd5e1; background: #f8fafc; }
    .tag-pill.selected { border-color: #8b5cf6; background: #f5f3ff; color: #7c3aed; }
    .tag-pill .pill-count { font-size: 0.65rem; }

    /* Active filters */
    .active-filters {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.5rem 0; flex-wrap: wrap; margin-top: 0.5rem;
    }
    .active-label { font-size: 0.8rem; color: #64748b; font-weight: 500; }
    .filter-chip {
      display: inline-flex; align-items: center;
      padding: 0.2rem 0.5rem; border-radius: 6px;
      background: #eff6ff; color: #2563eb; font-size: 0.78rem;
      cursor: pointer; font-weight: 500;
    }
    .filter-chip:hover { background: #dbeafe; }
    .filter-chip::after { content: "×"; margin-left: 0.3rem; font-weight: 700; }
    .clear-all {
      border: none; background: none; color: #ef4444;
      font-size: 0.78rem; cursor: pointer; font-weight: 500;
    }

    /* Sort */
    .sort-bar { margin-top: 0.75rem; }
    .sort-bar select {
      padding: 0.35rem 0.6rem; border-radius: 8px;
      border: 1px solid #e2e8f0; font-size: 0.82rem;
      color: #475569; background: #fff; cursor: pointer;
    }

    /* Recipe grid */
    .recipe-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1rem; padding-bottom: 3rem;
    }
    .recipe-card {
      display: flex; flex-direction: column;
      padding: 1.1rem; border-radius: 12px;
      border: 1px solid #e2e8f0; background: #fff;
      text-decoration: none; color: inherit;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    }
    .recipe-card:hover {
      border-color: #3b82f6; box-shadow: 0 4px 12px rgba(59,130,246,0.1);
      transform: translateY(-1px);
    }
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
    .card-cat {
      font-size: 0.72rem; font-weight: 600; padding: 0.15rem 0.5rem;
      border-radius: 6px; text-transform: capitalize;
    }
    .card-cat-ai { background: #f3e8ff; color: #7c3aed; }
    .card-cat-networking { background: #dbeafe; color: #2563eb; }
    .card-cat-security { background: #fee2e2; color: #dc2626; }
    .card-cat-deployments { background: #dcfce7; color: #16a34a; }
    .card-cat-storage { background: #fef9c3; color: #a16207; }
    .card-cat-observability { background: #ffedd5; color: #c2410c; }
    .card-cat-autoscaling { background: #cffafe; color: #0891b2; }
    .card-cat-configuration { background: #f1f5f9; color: #475569; }
    .card-cat-helm { background: #ccfbf1; color: #0d9488; }
    .card-cat-troubleshooting { background: #fce7f3; color: #be185d; }
    .card-diff {
      font-size: 0.7rem; font-weight: 500; padding: 0.1rem 0.4rem;
      border-radius: 4px; text-transform: capitalize;
    }
    .card-diff-beginner { background: #dcfce7; color: #16a34a; }
    .card-diff-intermediate { background: #fef9c3; color: #a16207; }
    .card-diff-advanced { background: #fee2e2; color: #dc2626; }
    .card-title {
      font-size: 0.95rem; font-weight: 700; margin: 0 0 0.4rem;
      line-height: 1.3; color: #1e293b;
    }
    .recipe-card:hover .card-title { color: #2563eb; }
    .card-desc {
      font-size: 0.8rem; color: #64748b; line-height: 1.45;
      margin: 0 0 0.6rem; flex: 1;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
