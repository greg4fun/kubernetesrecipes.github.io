---
const canonicalUrl = "https://kubernetes.recipes/recipes/security/custom-ca-openshift-kubernetes/";
const localPath = "/recipes/security/custom-ca-openshift-kubernetes/";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Redirecting to Custom CA OpenShift Kubernetes...</title>
  <meta name="robots" content="noindex, follow" />
  <link rel="canonical" href={canonicalUrl} />
  <meta http-equiv="refresh" content="0; url={localPath}" />
  <script is:inline define:vars={{ localPath }}>
    window.location.replace(localPath);
  </script>
</head>
<body>
  <p>Redirecting to <a href={localPath}>Custom CA OpenShift Kubernetes</a>...</p>
</body>
</html>
