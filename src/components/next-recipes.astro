---
/**
 * Next Recipes Component
 * 
 * Displays related recipes at the end of each recipe page.
 * Critical for internal linking and SEO.
 */

export interface Props {
  currentSlug: string;
  category: string;
  relatedSlugs?: string[];
  allRecipes: any[];
}

const { currentSlug, category, relatedSlugs = [], allRecipes } = Astro.props;

// Category display names + icons
const categoryNames: Record<string, string> = {
  networking: "Networking",
  storage: "Storage",
  deployments: "Deployments",
  security: "Security",
  observability: "Observability",
  autoscaling: "Autoscaling",
  troubleshooting: "Troubleshooting",
  configuration: "Configuration",
  helm: "Helm",
  ai: "AI & ML",
};
const categoryIcons: Record<string, string> = {
  networking: "🌐", storage: "💾", deployments: "🚀", security: "🔒",
  observability: "📊", autoscaling: "⚡", troubleshooting: "🔧",
  configuration: "⚙️", helm: "🎯", ai: "🤖",
};

// Tags of the current recipe (for shared-tag, cross-category relevance).
const currentRecipe = allRecipes.find(r => r.slug === currentSlug);
const currentTags: string[] = currentRecipe?.data?.tags || [];

// Hand-curated learning paths (optional "next step" feel where defined).
const suggestedProgression: Record<string, string[]> = {
  "rolling-update-deployment": ["blue-green-deployment", "canary-deployments"],
  "blue-green-deployment": ["canary-deployments", "argocd-gitops-deployment"],
  "canary-deployments": ["argocd-gitops-deployment", "flux-gitops-continuous-delivery"],
  "jobs-cronjobs": ["horizontal-pod-autoscaler", "pod-disruption-budgets"],
  "rbac-service-accounts": ["pod-security-standards", "network-policies"],
  "pod-security-standards": ["secrets-management-best-practices", "network-policies-advanced"],
  "prometheus-monitoring-setup": ["grafana-kubernetes-dashboards", "alertmanager-setup"],
  "grafana-kubernetes-dashboards": ["alertmanager-setup", "distributed-tracing-jaeger"],
};

const MAX = 6;
const bySlug = (slug: string) => allRecipes.find(r => r.slug === slug);

// Build a deduped, relevance-ordered set of internal links. Deeper internal
// linking spreads crawl equity and improves discovery/ranking across the whole
// catalog (every recipe page now links out to up to 6 related recipes instead
// of 3) — a single-component lever applied site-wide.
const seen = new Set<string>([currentSlug]);
const ordered: any[] = [];
const push = (r: any) => {
  if (r && !seen.has(r.slug)) { seen.add(r.slug); ordered.push(r); }
};

// 1. Curated learning path, 2. explicit relatedRecipes (topical, hand-picked).
(suggestedProgression[currentSlug] || []).map(bySlug).forEach(push);
relatedSlugs.map(bySlug).forEach(push);

// 3. Shared-tag matches in OTHER categories (topical cross-links, scored by
//    number of overlapping tags).
if (currentTags.length) {
  const tagSet = new Set(currentTags);
  allRecipes
    .filter(r => r.slug !== currentSlug && r.data.category !== category)
    .map(r => ({ r, score: (r.data.tags || []).filter((t: string) => tagSet.has(t)).length }))
    .filter(x => x.score > 0)
    .sort((a, b) => b.score - a.score || b.r.data.publishDate.valueOf() - a.r.data.publishDate.valueOf())
    .forEach(x => push(x.r));
}

// 4. Fill from the same category (recent first).
allRecipes
  .filter(r => r.data.category === category && r.slug !== currentSlug)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .forEach(push);

const displayRecipes = ordered.slice(0, MAX);
---

{displayRecipes.length > 0 && (
  <aside class="mt-16 pt-8 border-t border-slate-200">
    <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
      <span>📚</span> Continue Learning
    </h2>
    
    <div class="grid md:grid-cols-3 gap-4">
      {displayRecipes.map((recipe) => (
        <a 
          href={`/recipes/${recipe.data.category}/${recipe.slug}/`}
          class="group block p-4 bg-slate-50 rounded-lg hover:bg-blue-50 hover:border-blue-200 border border-transparent transition-all"
        >
          <div class="flex items-start gap-3">
            <span class="text-2xl opacity-50 group-hover:opacity-100 transition-opacity">
              {categoryIcons[recipe.data.category] || "📄"}
            </span>
            <div class="flex-1 min-w-0">
              <span class="text-xs text-slate-500 uppercase tracking-wider">
                {categoryNames[recipe.data.category] || recipe.data.category}
              </span>
              <h3 class="font-semibold text-slate-800 group-hover:text-blue-600 transition-colors line-clamp-2 mt-1">
                {recipe.data.title}
              </h3>
              <p class="text-sm text-slate-500 mt-1 line-clamp-2">
                {recipe.data.description}
              </p>
              <div class="flex items-center gap-2 mt-2 text-xs text-slate-400">
                <span>⏱ {recipe.data.timeToComplete}</span>
                <span class="capitalize">{recipe.data.difficulty}</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Link to category hub -->
    <div class="mt-6 text-center">
      <a 
        href={`/recipes/${category}/`}
        class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-medium transition-colors"
      >
        View all {categoryNames[category]} recipes →
      </a>
    </div>
  </aside>
)}
