#!/bin/sh
# Pre-commit hook: validate recipe content before every commit.
#
# Gates on:
#   - schema errors   (would break `astro build`)     -> verify-content.py
#   - link errors     (broken relatedRecipes + body links that 404)
#                                                      -> verify-links.py
# SEO warnings are reported but do not block.
#
# Enabled repo-wide via `core.hooksPath` (set by the package.json "prepare"
# script on install, or manually: git config core.hooksPath scripts/hooks).

set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Only run when staged changes touch recipe content or the validators themselves.
if git diff --cached --name-only --diff-filter=ACMR \
    | grep -Eq '^src/content/recipes/.*\.(md|mdx)$|^scripts/verify-(content|links)\.py$'; then
  :
else
  exit 0
fi

if command -v python3 >/dev/null 2>&1; then
  PY=python3
elif command -v python >/dev/null 2>&1; then
  PY=python
else
  echo "pre-commit: python not found; skipping content validation" >&2
  exit 0
fi

echo "pre-commit: validating recipe content..."
if ! "$PY" scripts/verify-content.py --quiet; then
  echo "" >&2
  echo "pre-commit: content validation FAILED — commit aborted." >&2
  echo "Fix the errors above, or inspect with: $PY scripts/verify-content.py" >&2
  echo "(To bypass for an emergency commit: git commit --no-verify)" >&2
  exit 1
fi

echo "pre-commit: checking internal links (related + body links)..."
if ! "$PY" scripts/verify-links.py >/dev/null; then
  echo "" >&2
  echo "pre-commit: link check FAILED — commit aborted." >&2
  echo "Broken relatedRecipes or body links (would 404). Inspect with:" >&2
  echo "  $PY scripts/verify-links.py" >&2
  echo "(To bypass for an emergency commit: git commit --no-verify)" >&2
  exit 1
fi

exit 0
